#!/bin/bash -e

# Use CROSS_PREFIX if set (defaults to /usr in hokuto)
PREFIX="${CROSS_PREFIX:-/usr}"
SBINDIR="${PREFIX}/bin"
LIBDIR="${PREFIX}/lib"
PKGCONFIGDIR="${LIBDIR}/pkgconfig"

# libcap Makefile doesn't strictly follow standard env vars, so we pass them explicitly
EXTRA_OPTS=""
if [ "${HOKUTO_CROSS:-0}" = "1" ]; then
    EXTRA_OPTS="CC=${CC:-cc} AR=${AR:-ar} RANLIB=${RANLIB:-ranlib} OBJCOPY=${OBJCOPY:-objcopy} STRIP=${STRIP:-strip} PKG_CONFIG=${PKG_CONFIG:-pkg-config}"
fi

sed -i '/install -m.*STA/d' libcap/Makefile

mk() {
    make \
        GOLANG=no \
        PREFIX="$PREFIX" \
        SBINDIR="$SBINDIR" \
        LIBDIR="$LIBDIR" \
        PKGCONFIGDIR="$PKGCONFIGDIR" \
        RAISE_SETFCAP=no \
        INDENT=" " \
        $EXTRA_OPTS \
        "$@"
}

mk
mk DESTDIR="$1" install

if [ "${HOKUTO_CROSS:-0}" != "1" ] && [ "$MULTILIB" = "1" ]; then
#32bit split package
make distclean
make CC="gcc -m32 -march=i686"
make CC="gcc -m32 -march=i686" lib=lib32 prefix=$PWD/DESTDIR/usr -C libcap install
dest_dir="$HOKUTO_SPLIT_DIR/lib32-$3"
install -d $dest_dir/usr/lib32/pkgconfig
cp -Rv DESTDIR/usr/lib32/* $dest_dir/usr/lib32
sed -e "s|^libdir=.*|libdir=/usr/lib32|" -i $dest_dir/usr/lib32/pkgconfig/lib{cap,psx}.pc
chmod -v 755 $dest_dir/usr/lib32/libcap.so.$2
fi
