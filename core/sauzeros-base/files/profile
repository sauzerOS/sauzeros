# /etc/profile

# Initialize Base PATH
PATH="/usr/bin:/usr/sbin:/sbin:/bin"

# Append "$1" to $PATH when not already in.
# This function API is accessible to scripts in /etc/profile.d
append_path () {
    case ":$PATH:" in
        *:"$1":*)
            ;;
        *)
            PATH="${PATH:+$PATH:}$1"
    esac
}

# Append default paths
append_path '/usr/local/sbin'
append_path '/usr/local/bin'

# Force PATH to be environment
export PATH

# System Defaults & Security
umask 022

# Load profiles from /etc/profile.d
if test -d /etc/profile.d/; then
	for profile in /etc/profile.d/*.sh; do
		test -r "$profile" && . "$profile"
	done
	unset profile
fi

# unset GLOBSORT, before anything else is sourced
unset -v GLOBSORT

# Unload profile API functions
unset -f append_path

# Global Shell Configuration
if [ -n "$BASH" ] && \
   [ -n "$PS1" ] && \
   [ -z "$POSIXLY_CORRECT" ] && \
   [ "${0#-}" != sh ] && \
   [ -r /etc/bashrc ]; then
    . /etc/bashrc
fi

# 6. Environment Variables & Hardware Optimization
export HISTSIZE=1000
export HISTIGNORE="&:[bf]g:exit"
export TERMINAL="xterm"
export EDITOR=nano

# XZ multi-threading optimization from your LFS setup
export XZ_OPT="-T0 -M 90%"

# Load system locale securely if the file exists
[ -r /etc/locale.conf ] && export $(cat /etc/locale.conf)

# 7. XDG Base Directory Specification Defaults
export XDG_DATA_DIRS=${XDG_DATA_DIRS:-/usr/share/}
export XDG_CONFIG_DIRS=${XDG_CONFIG_DIRS:-/etc/xdg/}
export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/tmp/xdg-$USER}

# Modernization Cleanups
unset TERMCAP
unset MANPATH

# 9. Global Aliases
alias ls='ls --color=auto'
alias grep='grep --color=auto'
