#!/bin/bash

# --- Configuration ---
TOKEN="your_api_token"
ZONE_ID="your_zone_id"
RECORD_NAME="example.com"  # e.g., "home.yourdomain.com" or "yourdomain.com"

# Protocol Toggles (Set to true to enable, false to disable)
ENABLE_IPV4=true
ENABLE_IPV6=true

# Cache files
IP4_FILE="/var/tmp/last_cloudflare_ip4.txt"
IP6_FILE="/var/tmp/last_cloudflare_ip6.txt"
ID4_FILE="/var/tmp/cloudflare_record_id4.txt"
ID6_FILE="/var/tmp/cloudflare_record_id6.txt"

# IPv6 services used both to discover the public address and to verify which
# local source address can actually reach the internet.
IP6_SERVICES=(
    "https://api64.ipify.org"
    "https://ifconfig.me/ip"
)

# --- Function: Get or Fetch Record ID ---
get_record_id() {
    local type=$1
    local id_file=$2
    local record_id=""

    if [[ -f "$id_file" ]]; then
        record_id=$(cat "$id_file")
    else
        echo "Fetching $type Record ID from Cloudflare"
        record_id=$(curl -s -X GET "https://api.cloudflare.com/client/v4/zones/$ZONE_ID/dns_records?type=$type&name=$RECORD_NAME" \
            -H "Authorization: Bearer $TOKEN" \
            -H "Content-Type: application/json" | jq -r '.result[0].id')

        if [[ "$record_id" != "null" && -n "$record_id" ]]; then
            echo "$record_id" > "$id_file"
            echo "Saved $type Record ID: $record_id"
        else
            echo "Warning: Could not find $type record for $RECORD_NAME."
            record_id=""
        fi
    fi
    echo "$record_id"
}

# --- Function: Update Cloudflare Record ---
update_record() {
    local type=$1
    local record_id=$2
    local current_ip=$3
    local ip_file=$4
    local id_file=$5

    # Check against cached IP
    if [[ -f "$ip_file" ]]; then
        local old_ip=$(cat "$ip_file")
        if [[ "$current_ip" == "$old_ip" ]]; then
            echo "$type IP has not changed ($current_ip). Skipping update."
            return 0
        fi
    fi

    echo "Updating Cloudflare $type record to $current_ip"
    local response=$(curl -s -X PATCH "https://api.cloudflare.com/client/v4/zones/$ZONE_ID/dns_records/$record_id" \
        -H "Authorization: Bearer $TOKEN" \
        -H "Content-Type: application/json" \
        --data "{\"content\": \"$current_ip\"}")

    if [[ "$response" == *"\"success\":true"* ]]; then
        echo "$current_ip" > "$ip_file"
        echo "$type IP successfully updated to $current_ip"
    else
        echo "$type Cloudflare update failed. Response: $response"
        # If record ID is invalid or unauthorized, clear the cached ID file
        [[ "$response" == *"\"code\":6003"* || "$response" == *"\"code\":81044"* ]] && rm -f "$id_file"
    fi
}

# --- Function: Get current active IPv6 address ---
get_current_ipv6() {
    local address response service

    while read -r address; do
        for service in "${IP6_SERVICES[@]}"; do
            response=$(curl -fsS -6 --connect-timeout 10 --max-time 20 --interface "$address" "$service" 2>/dev/null) || continue

            if [[ "$response" == "$address" ]]; then
                echo "$address"
                return 0
            fi
        done
    done < <(
        ip -o -6 addr show scope global up |
            awk '
                / tentative | dadfailed | deprecated / { next }
                {
                    split($4, address, "/")
                    print address[1]
                }
            '
    )

    return 1
}

# --- Main Logic ---

# === IPv4 Track ===
if [[ "$ENABLE_IPV4" = true ]]; then
    RECORD_ID4=$(get_record_id "A" "$ID4_FILE")
    CURRENT_IP4=$(curl -s -4 https://api.ipify.org || curl -s -4 https://ifconfig.me)

    if [[ -n "$RECORD_ID4" && -n "$CURRENT_IP4" ]]; then
        update_record "A" "$RECORD_ID4" "$CURRENT_IP4" "$IP4_FILE" "$ID4_FILE"
    else
        echo "Skipping IPv4 update (Missing Record ID or Public IP)."
    fi
else
    echo "IPv4 update is disabled in configuration."
fi

# === IPv6 Track ===
if [[ "$ENABLE_IPV6" = true ]]; then
    RECORD_ID6=$(get_record_id "AAAA" "$ID6_FILE")
    CURRENT_IP6=$(get_current_ipv6)

    if [[ -n "$RECORD_ID6" && -n "$CURRENT_IP6" ]]; then
        update_record "AAAA" "$RECORD_ID6" "$CURRENT_IP6" "$IP6_FILE" "$ID6_FILE"
    else
        echo "Skipping IPv6 update (Missing Record ID or Public IP)."
    fi
else
    echo "IPv6 update is disabled in configuration."
fi
