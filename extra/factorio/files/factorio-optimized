#!/usr/bin/env bash
set -e
### CONFIG ###
FACTORIO_BIN="factorio"
#HUGEPAGES_2MB=4096          # 4096 * 2MB = 8GB
MIMALLOC_PATH="$(ldconfig -p | grep libmimalloc.so | head -n1 | awk '{print $4}')"

if [[ -z "$MIMALLOC_PATH" ]]; then
    echo "libmimalloc.so not found. Install mimalloc or adjust path."
    exit 1
fi

