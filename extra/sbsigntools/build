#!/bin/bash -e

# openssl 4 fix
patch -Np1 -i sbsigntools-0.9.5-openssl4.patch

git submodule init
git config submodule."lib/ccan.git".url ccan
git -c protocol.file.allow=always submodule update
./autogen.sh

configure_options=(
  --prefix=/usr
  --bindir=/usr/bin
  --sbindir=/usr/bin
  --libexecdir=/usr/lib
  --mandir=/usr/share/man
  --sysconfdir=/etc
)

CFLAGS="${CFLAGS} -fshort-wchar -Wno-error" \
./configure "${configure_options[@]}"
make
make DESTDIR="${1}" install
