diff --git a/src/fileio.c b/src/fileio.c
index 032eb1e..a2a3641 100644
--- a/src/fileio.c
+++ b/src/fileio.c
@@ -39,7 +39,13 @@
 #include <openssl/bio.h>
 #include <openssl/pem.h>
 #include <openssl/err.h>
+#include <openssl/ui.h>
+#if OPENSSL_VERSION_NUMBER < 0x40000000L
 #include <openssl/engine.h>
+#else
+#include <openssl/provider.h>
+#include <openssl/store.h>
+#endif
 
 #include <ccan/talloc/talloc.h>
 #include <ccan/read_write_all/read_write_all.h>
@@ -62,6 +68,69 @@ static int ui_read(UI *ui, UI_STRING *uis)
 
 EVP_PKEY *fileio_read_engine_key(const char *engine, const char *filename)
 {
+#if OPENSSL_VERSION_NUMBER >= 0x40000000L
+	OSSL_PROVIDER *provider;
+	OSSL_STORE_CTX *store;
+	OSSL_STORE_INFO *info;
+	UI_METHOD *ui;
+	EVP_PKEY *pkey = NULL;
+
+	/*
+	 * ENGINE was removed in OpenSSL 4.  Treat the engine name as a
+	 * provider name and the key filename as an OSSL_STORE URI.  This
+	 * retains the command-line interface while allowing, for example,
+	 * --engine pkcs11 --key 'pkcs11:...'.
+	 */
+	provider = OSSL_PROVIDER_load(NULL, engine);
+	if (!provider) {
+		fprintf(stderr, "Failed to load provider: %s\n", engine);
+		ERR_print_errors_fp(stderr);
+		return NULL;
+	}
+
+	ui = UI_create_method("sbsigntools");
+	if (!ui) {
+		fprintf(stderr, "Failed to create UI method\n");
+		ERR_print_errors_fp(stderr);
+		OSSL_PROVIDER_unload(provider);
+		return NULL;
+	}
+	UI_method_set_reader(ui, ui_read);
+
+	store = OSSL_STORE_open_ex(filename, NULL, NULL, ui, NULL, NULL,
+			NULL, NULL);
+	if (!store) {
+		fprintf(stderr, "Failed to open key URI: %s\n", filename);
+		ERR_print_errors_fp(stderr);
+		goto out_provider;
+	}
+
+	while (!OSSL_STORE_eof(store)) {
+		info = OSSL_STORE_load(store);
+		if (!info) {
+			if (OSSL_STORE_error(store))
+				break;
+			continue;
+		}
+		if (OSSL_STORE_INFO_get_type(info) == OSSL_STORE_INFO_PKEY) {
+			pkey = OSSL_STORE_INFO_get1_PKEY(info);
+			OSSL_STORE_INFO_free(info);
+			break;
+		}
+		OSSL_STORE_INFO_free(info);
+	}
+
+	if (!pkey) {
+		fprintf(stderr, "Failed to load private key: %s\n", filename);
+		ERR_print_errors_fp(stderr);
+	}
+	OSSL_STORE_close(store);
+
+out_provider:
+	UI_destroy_method(ui);
+	OSSL_PROVIDER_unload(provider);
+	return pkey;
+#else
 	UI_METHOD *ui;
 	ENGINE *e;
 	EVP_PKEY *pkey = NULL;
@@ -95,6 +164,7 @@ EVP_PKEY *fileio_read_engine_key(const char *engine, const char *filename)
  out_free:
 	ENGINE_free(e);
 	return pkey;
+#endif
 }
 
 EVP_PKEY *fileio_read_pkey(const char *filename)
