#!/bin/sh -e
# Auto-generated from PKGBUILD
# You may need to adjust this script for Hokuto

# Prepare phase
# Provide wrappers to compiler tools
rm -rf wrappers && mkdir wrappers
_make_wrappers

[ ! -d build ] && mkdir build

cd proton-cachyos

[ ! -d contrib ] && mkdir -p contrib
mv "."/wine-gecko-2.47.4-x86{,_64}.tar.xz contrib/
mv "."/wine-mono-11.2.0-x86.tar.xz contrib/
mv "."/xalia-0.4.9-net48-mono.zip contrib/

_submodules=(
    OpenXR-SDK
    SPIRV-Headers
    Vulkan-Headers
    dav1d
    dxvk
    dxvk-nvapi
    extras/d7vk
    extras/discord-rpc-bridge
    extras/dxvk-low-latency
    extras/dxvk-sarek
    ffmpeg
    fonts/liberation-fonts
    glslang
    graphene
    gst-orc
    gst-plugins-rs
    gstreamer
    libsoup
    meson
    nvidia-libs/dxvk-nvapi
    nvidia-libs/nvcuda
    nvidia-libs/nvcuda32
    nvidia-libs/nvenc
    nvidia-libs/nvenc32
    nvidia-libs/wine-nvml
    nvidia-libs/wine-nvoptix
    openvr
    protonfixes
    vkd3d
    vkd3d-proton
    vklayers/Vulkan-Utility-Libraries
    vklayers/low_latency_layer
    vklayers/pyroveil
    vklayers/vkbasalt
    wine
)

# Explicitly set origin URL for submodules using relative paths
git remote set-url origin https://github.com/CachyOS/proton-cachyos.git
git submodule update --init --filter=tree:0 --recursive ${_submodules[@]}

for rustlib in gst-plugins-rs; do
pushd $rustlib
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_HOME="${SRCDEST}"/proton-cargo
    export CARGO_NET_GIT_FETCH_WITH_CLI=true
    cargo fetch --locked --target i686-unknown-linux-gnu
    cargo fetch --locked --target x86_64-unknown-linux-gnu
popd
done

# Build phase
export PATH="$(pwd)/wrappers:$PATH"

local -a split=($CFLAGS)
local -A flags
for opt in "${split[@]}"; do flags["${opt%%=*}"]="${opt##*=}"; done
local march="${flags["-march"]:-nocona}"
local mtune="${flags["-mtune"]:-core-avx2}"

CFLAGS="-O2 -march=${march} -mtune=${mtune}"
CXXFLAGS="-O2 -march=${march} -mtune=${mtune}"
RUSTFLAGS="-C opt-level=3 -C target-cpu=${march}"
LDFLAGS="-Wl,-O1,--sort-common,--as-needed"

export CFLAGS CXXFLAGS RUSTFLAGS LDFLAGS

export RUSTUP_TOOLCHAIN=stable
export CARGO_HOME="${SRCDEST}"/proton-cargo

cd build
ROOTLESS_CONTAINER="" \
../proton-cachyos/configure.sh \
    --container-engine="none" \
    --proton-sdk-image="" \
    --build-name="proton-cachyos-native" \
    --without-steamrt-depends \
    --without-tts

SUBJOBS=$([[ "$MAKEFLAGS" =~ -j\ *([1-9][0-9]*) ]] && echo "${BASH_REMATCH[1]}" || echo "$(nproc)") \
    make -j1 dist

cd dist
sed -r \
  -e "s|##INSTALL_PATH##|.|" \
  -e "s|##DISPLAY_NAME##|proton-cachyos-11.0-20260702 (native)|" \
  -e "s|##INTERNAL_TOOL_NAME##|proton-cachyos-native|" \
  "compatibilitytool.vdf.template" > compatibilitytool.vdf

# Install phase
cd build

# Delete the intermediate build directories to free space (mostly for my github actions)
rm -rf dst-* obj-* src-* pfx-*

local _compatdir="${1}/usr/share/steam/compatibilitytools.d"
mkdir -p "${_compatdir}/proton-cachyos-native"
rsync --delete -arx dist/* "${_compatdir}/proton-cachyos-native"

mkdir -p "${1}/usr/share/licenses/proton-cachyos-native"
mv "${_compatdir}/proton-cachyos-native"/{PATENTS.AV1,LICENSE{,.OFL}} \
    "${1}/usr/share/licenses/proton-cachyos-native"

# Load ntsync module
install -Dm644 "ntsync.conf" "${1}/usr/lib/modules-load.d/10-proton-cachyos-native.conf"

cd "${_compatdir}/proton-cachyos-native/files"

local _geckodir="share/wine/gecko/wine-gecko-2.47.4"
i686-w64-mingw32-strip --strip-debug \
    $(find "${_geckodir}"-x86 -iname "*.dll" -or -iname "*.exe")
x86_64-w64-mingw32-strip --strip-debug \
    $(find "${_geckodir}"-x86_64 -iname "*.dll" -or -iname "*.exe")

local _monodir="share/wine/mono/wine-mono-11.2.0"
i686-w64-mingw32-strip --strip-debug \
    $(find "${_monodir}"/lib/mono -iname "*.dll" -or -iname "*.exe")
i686-w64-mingw32-strip --strip-debug \
    "${_monodir}"/lib/x86/*.dll \
    $(find "${_monodir}" -iname "*x86.dll" -or -iname "*x86.exe")
x86_64-w64-mingw32-strip --strip-debug \
    "${_monodir}"/lib/x86_64/*.dll \
    $(find "${_monodir}" -iname "*x86_64.dll" -or -iname "*x86_64.exe")
