         }
     }
 }
+
+/**
+ * Pauses or resumes an active timer without resetting the current attempt.
+ *
+ * @param win The LibreSplit window
+ */
+void timer_pause_resume(LSAppWindow* win)
+{
+    if (!win->timer || !win->timer->started
+        || win->timer->curr_split >= win->timer->game->split_count)
+        return;
+
+    if (win->timer->running) {
+        timer_stop(win);
+    } else {
+        timer_start(win);
+    }
+}
