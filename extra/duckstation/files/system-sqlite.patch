From: sauzerOS <packaging@sauzeros.org>
Subject: [PATCH] Use the system SQLite library on Linux

The Linux package provides SQLite as a normal runtime dependency instead of
shipping another copy beside the DuckStation executable.  Do not require the
bundled-dependency CMake target, and let dlopen resolve the versioned library
through the system dynamic-linker search path.

diff --git a/src/util/CMakeLists.txt b/src/util/CMakeLists.txt
index d05bce359..89638336a 100644
--- a/src/util/CMakeLists.txt
+++ b/src/util/CMakeLists.txt
@@ -275,7 +275,7 @@ function(add_util_resources target)
   endif()
 
   # Copy dynamically-loaded libraries (harfbuzz/shaderc/spirv-cross) into the bundle.
-  bundle_libraries(${target} spirv-cross-c-shared Shaderc::shaderc_shared SQLite3::sqlite3-shared)
+  bundle_libraries(${target} spirv-cross-c-shared Shaderc::shaderc_shared)
   if(APPLE)
     bundle_libraries(${target} harfbuzz::harfbuzz)
   endif()
diff --git a/src/util/sqlite_helpers.cpp b/src/util/sqlite_helpers.cpp
index 30f2404ae..3642ea719 100644
--- a/src/util/sqlite_helpers.cpp
+++ b/src/util/sqlite_helpers.cpp
@@ -43,7 +43,13 @@ bool DynSqlite::Open(Error* error)
   std::call_once(s_locals.sqlite_init_flag, [&error]() {
     Error lerror;
     DynamicLibrary lib;
-    if (!lib.Open(DynamicLibrary::GetBundledLibraryPath("sqlite3", lib_major_version).c_str(), &lerror))
+#ifdef _WIN32
+    const std::string library_path = DynamicLibrary::GetBundledLibraryPath("sqlite3", lib_major_version);
+#else
+    // Use the system library instead of looking beside the executable.
+    const std::string library_path = DynamicLibrary::GetVersionedFilename("sqlite3", lib_major_version);
+#endif
+    if (!lib.Open(library_path.c_str(), &lerror))
     {
       ERROR_LOG("Failed to load sqlite: {}", lerror.GetDescription());
       Error::SetStringFmt(error, "Failed to load sqlite: {}", lerror.GetDescription());
