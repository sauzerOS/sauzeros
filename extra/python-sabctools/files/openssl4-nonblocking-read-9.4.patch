From: sauzerOS <packaging@sauzeros.org>
Subject: [PATCH] Clear swallowed OpenSSL errors after a successful read

unlocked_ssl_recv_into() batches TLS records by continuing to call
SSL_read_ex() until the nonblocking socket reports WANT_READ. If data was
read before that condition, the function returns the data and intentionally
hides WANT_READ from its caller.

OpenSSL 4 leaves an error associated with that final read on the thread-local
error queue. Since the fast path bypasses CPython's normal SSL error handling,
the queue was not drained and the next SSLSocket.send() failed with a bogus
SSLEOFError. Clear the swallowed error and reset CPython's cached socket error
before reporting the successful read.

diff --git a/src/unlocked_ssl.cc b/src/unlocked_ssl.cc
index 4d0aa98..f25310c 100644
--- a/src/unlocked_ssl.cc
+++ b/src/unlocked_ssl.cc
@@ -28,6 +28,7 @@
 static int (*SSL_read_ex)(void*, void*, size_t, size_t*) = NULL;
 static int (*SSL_get_error)(void*, int) = NULL;
 static int (*SSL_get_shutdown)(void*) = NULL;
+static void (*ERR_clear_error)(void) = NULL;
 static PyObject *SSLWantReadError = NULL;
 static PyObject *SSLWantWriteError = NULL;
 static PyObject *SSLSocketType = NULL;
@@ -118,6 +119,7 @@ void openssl_init() {
     *(void**)&SSL_read_ex = GetProcAddress(openssl_handle, "SSL_read_ex");
     *(void**)&SSL_get_error = GetProcAddress(openssl_handle, "SSL_get_error");
     *(void**)&SSL_get_shutdown = GetProcAddress(openssl_handle, "SSL_get_shutdown");
+    *(void**)&ERR_clear_error = GetProcAddress(openssl_handle, "ERR_clear_error");
 #else
     // Find library at "import ssl; print(ssl._ssl.__file__)"
 
@@ -132,6 +134,7 @@ void openssl_init() {
     *(void**)&SSL_read_ex = dlsym(openssl_handle, "SSL_read_ex");
     *(void**)&SSL_get_error = dlsym(openssl_handle, "SSL_get_error");
     *(void**)&SSL_get_shutdown = dlsym(openssl_handle, "SSL_get_shutdown");
+    *(void**)&ERR_clear_error = dlsym(openssl_handle, "ERR_clear_error");
 
 error:
     if (!openssl_linked() && openssl_handle) dlclose(openssl_handle);
@@ -152,6 +155,7 @@ bool openssl_linked() {
     return SSL_read_ex &&
         SSL_get_error &&
         SSL_get_shutdown &&
+        ERR_clear_error &&
         SSLWantReadError &&
         SSLWantWriteError &&
         SSLSocketType;
@@ -203,6 +207,9 @@ static PyObject* unlocked_ssl_recv_into_impl(PySSLSocket *self, Py_ssize_t len,
         self->err = err;
 
         if (count > 0) {
+            ERR_clear_error();
+            err = { 0 };
+            self->err = err;
             break;
         }
 
diff --git a/tests/test_unlocked_ssl.py b/tests/test_unlocked_ssl.py
index ddafd16..44ab75a 100644
--- a/tests/test_unlocked_ssl.py
+++ b/tests/test_unlocked_ssl.py
@@ -285,6 +285,17 @@ def test_unlocked_ssl_recv_into_response(client, buffer):
     assert buffer[:bytes_received].tobytes() == b"TEST"
 
 
+def test_write_after_unlocked_ssl_recv(client, buffer):
+    bytes_received = unlocked_ssl_recv_into_wrapper(client, b"GREETING", buffer)
+    assert buffer[:bytes_received].tobytes() == b"GREETING"
+
+    # The optimized reader may consume all currently available TLS records
+    # before returning. Any internal WANT_READ error must not leak into the
+    # next operation on the socket.
+    bytes_received = unlocked_ssl_recv_into_wrapper(client, b"COMMAND", buffer)
+    assert buffer[:bytes_received].tobytes() == b"COMMAND"
+
+
 def test_unlocked_ssl_recv_into_bulk_response(client):
     # 131072 bytes divide up into 8 TLS records (16 KB each)
     # In nonblocking mode, we should be able to read all eight in a single
