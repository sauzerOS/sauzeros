From: sauzerOS <packaging@sauzeros.org>
Subject: [PATCH] Match CPython's OpenSSL 4 SSLSocket layout

CPython's OpenSSL 4 support adds got_eof_error to PySSLSocket and removes
the cached _PySSLError member.  sauzerOS backports that change to Python
3.14, while upstream sabctools assumes the layout starts at Python 3.15.
Its fast read path consequently writes SSL_ERROR_WANT_READ into
got_eof_error, so the next regular SSLSocket operation raises a bogus
SSLEOFError.

Use CPython's OpenSSL 4 layout starting with Python 3.14.

diff --git a/src/unlocked_ssl.cc b/src/unlocked_ssl.cc
index 24c6c91..e39e9d2 100644
--- a/src/unlocked_ssl.cc
+++ b/src/unlocked_ssl.cc
@@ -50,7 +50,7 @@ typedef struct {
     int socket_type;
     PyObject *owner; /* Python level "owner" passed to servername callback */
     PyObject *server_hostname;
-#if PY_VERSION_HEX >= SABCTOOLS_PY_HEX(3, 15)
+#if PY_VERSION_HEX >= SABCTOOLS_PY_HEX(3, 14)
     int got_eof_error;
 #else
     _PySSLError err; /* last seen error from various sources */
@@ -255,7 +255,7 @@ static PyObject* unlocked_ssl_recv_into_impl(PySSLSocket *self, Py_ssize_t len,
         } while (len > 0);
         err = _PySSL_errno(retval == 0, self->ssl, retval);
         Py_END_ALLOW_THREADS;
-#if PY_VERSION_HEX < SABCTOOLS_PY_HEX(3, 15)
+#if PY_VERSION_HEX < SABCTOOLS_PY_HEX(3, 14)
         self->err = err;
 #endif
 
diff --git a/tests/test_unlocked_ssl.py b/tests/test_unlocked_ssl.py
index ad4c8c2..d69ae54 100644
--- a/tests/test_unlocked_ssl.py
+++ b/tests/test_unlocked_ssl.py
@@ -285,6 +285,17 @@ def test_unlocked_ssl_recv_into_response(client, buffer):
     assert buffer[:bytes_received].tobytes() == b"TEST"
 
 
+def test_write_after_unlocked_ssl_recv(client, buffer):
+    bytes_received = unlocked_ssl_recv_into_wrapper(client, b"GREETING", buffer)
+    assert buffer[:bytes_received].tobytes() == b"GREETING"
+
+    # The optimized reader may consume all currently available TLS records
+    # before returning. Its internal WANT_READ must not mark the CPython
+    # socket as having reached EOF.
+    bytes_received = unlocked_ssl_recv_into_wrapper(client, b"COMMAND", buffer)
+    assert buffer[:bytes_received].tobytes() == b"COMMAND"
+
+
 def test_unlocked_ssl_recv_into_bulk_response(client):
