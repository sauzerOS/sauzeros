# NOTE: needs to be replaced by openbios
_pick "$1" qemu-system-sparc-firmware usr/share/qemu/openbios-sparc{32,64}
_pick "$1" qemu-system-sparc-firmware usr/share/qemu/QEMU,{cgthree,tcx}.bin

_pick "$1" qemu-system-tricore usr/bin/qemu-system-tricore
_pick "$1" qemu-system-tricore usr/share/man/man1/qemu-system-tricore.1*

_pick "$1" qemu-system-x86 usr/bin/qemu-system-{i386,x86_64}
