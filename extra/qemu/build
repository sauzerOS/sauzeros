_pick "$1" qemu-system-x86-firmware usr/share/qemu/{kvmvapic,{linuxboot,multiboot}_dma,pvh}.bin
_pick "$1" qemu-system-x86-firmware usr/share/qemu/qboot.rom
_pick "$1" qemu-system-x86-firmware usr/share/qemu/edk2-i386*
_pick "$1" qemu-system-x86-firmware usr/share/qemu/edk2-x86_64*
_pick "$1" qemu-system-x86-firmware usr/share/qemu/firmware/50-edk2-i386-secure.json
_pick "$1" qemu-system-x86-firmware usr/share/qemu/firmware/60-edk2-i386.json
_pick "$1" qemu-system-x86-firmware usr/share/qemu/firmware/50-edk2-x86_64-secure.json
_pick "$1" qemu-system-x86-firmware usr/share/qemu/firmware/60-edk2-x86_64.json

_pick "$1" qemu-system-xtensa usr/bin/qemu-system-xtensa{,eb}
_pick "$1" qemu-system-xtensa usr/share/man/man1/qemu-system-xtensa{,eb}.1*

_pick "$1" qemu-tests usr/lib/qemu/accel-qtest.so

_pick "$1" qemu-tools usr/bin/{elf2dmp,qemu-{edid,keymap}}
_pick "$1" qemu-tools usr/share/qemu/trace-events-all

install -vDm 644 scripts/dump-guest-memory.py -t "$HOKUTO_SPLIT_DIR/qemu-tools/usr/share/qemu/"
install -vDm 755 scripts/simpletrace.py -t "$HOKUTO_SPLIT_DIR/qemu-tools/usr/share/qemu/"
install -vDm 644 scripts/tracetool/*.py -t "$HOKUTO_SPLIT_DIR/qemu-tools/usr/share/qemu/tracetool/"
install -vDm 644 scripts/tracetool/backend/*.py -t "$HOKUTO_SPLIT_DIR/qemu-tools/usr/share/qemu/tracetool/backend/"
install -vDm 644 scripts/tracetool/format/*.py -t "$HOKUTO_SPLIT_DIR/qemu-tools/usr/share/qemu/tracetool/format/"

_pick "$1" qemu-ui-curses usr/lib/qemu/ui-curses.so
_pick "$1" qemu-ui-dbus usr/lib/qemu/ui-dbus.so
_pick "$1" qemu-ui-egl-headless usr/lib/qemu/ui-egl-headless.so
_pick "$1" qemu-ui-gtk usr/lib/qemu/ui-gtk.so
_pick "$1" qemu-ui-opengl usr/lib/qemu/ui-opengl.so
_pick "$1" qemu-ui-sdl usr/lib/qemu/ui-sdl.so
_pick "$1" qemu-ui-spice-app usr/lib/qemu/ui-spice-app.so
_pick "$1" qemu-ui-spice-core usr/lib/qemu/ui-spice-core.so

_pick "$1" qemu-user-static usr/bin/qemu-*-static
_pick "$1" qemu-user-static-binfmt usr/lib/binfmt.d/*-static.conf

_pick "$1" qemu-user usr/bin/qemu-{aarch64{,_be},alpha,arm{,eb},hexagon,hppa,i386,loongarch64,m68k,microblaze{,el},mips{,64,64el,el,n32,n32el},or1k,ppc{,64,64le},riscv{32,64},s390x,sh4{,eb},sparc{,32plus,64},x86_64,xtensa{,eb}}
_pick "$1" qemu-user-binfmt usr/lib/binfmt.d/*.conf

_pick "$1" qemu-vhost-user-gpu usr/lib/qemu/vhost-user-gpu
