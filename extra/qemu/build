  _pick "$1" qemu-vmsr-helper usr/bin/qemu-vmsr-helper
  install -vDm 644 contrib/systemd/qemu-vmsr-helper.{service,socket} -t "$HOKUTO_SPLIT_DIR/qemu-vmsr-helper/usr/lib/systemd/system/"
fi
install -d $HOKUTO_SPLIT_DIR/qemu-base/var/db/hokuto/installed/qemu-base/
touch $HOKUTO_SPLIT_DIR/qemu-base/var/db/hokuto/installed/qemu-base/.touch
install -d $HOKUTO_SPLIT_DIR/qemu-desktop/var/db/hokuto/installed/qemu-desktop/
touch $HOKUTO_SPLIT_DIR/qemu-desktop/var/db/hokuto/installed/qemu-desktop/.touch
