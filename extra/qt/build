#!/bin/bash -e

# openssl 4 patch
patch -Np1 -d qtbase -i ../qt-everywhere-src-6.11.1-openssl4_fix-1.patch

# skip qtwebengine, qt3d, qtopcua
rm -rf qtwebengine qt3d qtopcua

cmake -B build \
  -D CMAKE_INSTALL_PREFIX=/usr \
  -D CMAKE_BUILD_TYPE=RelWithDebInfo \
  -D INSTALL_BINDIR=lib/qt6/bin \
  -D INSTALL_PUBLICBINDIR=bin \
  -D INSTALL_LIBEXECDIR=lib/qt6 \
  -D INSTALL_DOCDIR=share/doc/qt6 \
  -D INSTALL_ARCHDATADIR=lib/qt6 \
  -D INSTALL_DATADIR=share/qt6 \
  -D INSTALL_INCLUDEDIR=include/qt6 \
  -D INSTALL_MKSPECSDIR=lib/qt6/mkspecs \
  -D INSTALL_EXAMPLESDIR=share/doc/qt6/examples \
  -D FEATURE_journald=ON \
  -D FEATURE_libproxy=ON \
  -D FEATURE_dbus_linked=ON \
  -D FEATURE_openssl_linked=ON \
  -D FEATURE_system_sqlite=ON \
  -D FEATURE_system_xcb_xinput=ON \
  -D FEATURE_no_direct_extern_access=ON \
  -D CMAKE_INTERPROCEDURAL_OPTIMIZATION=ON \
  -D CMAKE_MESSAGE_LOG_LEVEL=STATUS

cmake --build build
DESTDIR=$1 cmake --install build

install -d -m755 "$1"/usr/include/qt6xcb-private/gl_integrations
cp -r qtbase/src/plugins/platforms/xcb/*.h "$1"/usr/include/qt6xcb-private/
cp -r qtbase/src/plugins/platforms/xcb/gl_integrations/*.h "$1"/usr/include/qt6xcb-private/gl_integrations/

# remove qml examples module
rm -rf "$1"/usr/include/qt6/QtQmlAssetDownloader
rm -rf "$1"/usr/lib/cmake/Qt6QmlAssetDownloaderPrivate
rm -f  "$1"/usr/lib/cmake/Qt6Qml/QmlPlugins/*AssetDownloader*
rm -f  "$1"/usr/lib/libQt6QmlAssetDownloader.{a,prl}
rm -f  "$1"/usr/lib/qt6/metatypes/qt6qmlassetdownloaderprivate_metatypes.json
rm -f  "$1"/usr/lib/qt6/mkspecs/modules/qt_lib_qmlassetdownloader_private.pri
rm -f  "$1"/usr/lib/qt6/modules/QmlAssetDownloaderPrivate.json
rm -rf "$1"/usr/lib/qt6/qml/Qt/labs/assetdownloader

# qt-5compat
_pick "$1" qt-5compat usr/include/qt6/QtCore5Compat/
_pick "$1" qt-5compat usr/lib/cmake/Qt6/FindWrapIconv.cmake
_pick "$1" qt-5compat usr/lib/cmake/Qt6BuildInternals/StandaloneTests/Qt5CompatTestsConfig.cmake
_pick "$1" qt-5compat usr/lib/cmake/Qt6Core5Compat/
_pick "$1" qt-5compat usr/lib/cmake/Qt6Core5CompatPrivate/
_pick "$1" qt-5compat usr/lib/cmake/Qt6Qml/QmlPlugins/Qt6qtgraphicaleffects*
_pick "$1" qt-5compat usr/lib/libQt6Core5Compat*
_pick "$1" qt-5compat usr/lib/pkgconfig/Qt6Core5Compat.pc
_pick "$1" qt-5compat usr/lib/qt6/metatypes/qt6core5compat_metatypes.json
_pick "$1" qt-5compat usr/lib/qt6/mkspecs/modules/qt_lib_core5compat*
_pick "$1" qt-5compat usr/lib/qt6/modules/Core5Compat.json
_pick "$1" qt-5compat usr/lib/qt6/qml/Qt5Compat/
_pick "$1" qt-5compat usr/lib/qt6/sbom/qt5compat*

# qt-canvaspainter

_pick "$1" qt-canvaspainter usr/include/qt6/QtCanvasPainter/
_pick "$1" qt-canvaspainter usr/lib/cmake/Qt6BuildInternals/StandaloneTests/QtCanvasPainterTestsConfig.cmake
_pick "$1" qt-canvaspainter usr/lib/cmake/Qt6CanvasPainter/
