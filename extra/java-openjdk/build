#!/bin/bash -e

# remove -j from MAKEFLAGS to prevent build fail
MAKEFLAG_J=$(echo ${MAKEFLAGS} | sed -En 's/.*-j([0-9]+).*/\1/p')
export MAKEFLAGS=${MAKEFLAGS/-j${MAKEFLAG_J}/}

# Avoid optimization of HotSpot to be lowered from O3 to O2
# local _CFLAGS="${CFLAGS//-O2/-O3} ${CPPFLAGS} -fcommon"
_CFLAGS="${CFLAGS//-O2/-O3} ${CPPFLAGS} -fcommon"
_CXXFLAGS="${CXXFLAGS//-O2/-O3} ${CPPFLAGS} -fcommon"
_LDFLAGS=${LDFLAGS}

# TODO: Should be rechecked for the next releases
# compiling with -fexceptions leads to:
# /usr/bin/ld: /build/java-openjdk/src/jdk17u-jdk-17.0.3-2/build/linux-x86_64-server-release/hotspot/variant-server/libjvm/objs/zPhysicalMemory.o: in function `ZList<ZMemory>::~ZList()':
# /build/java-openjdk/src/jdk17u-jdk-17.0.3-2/src/hotspot/share/gc/z/zList.hpp:54: undefined reference to `ZListNode<ZMemory>::~ZListNode()'
# collect2: error: ld returned 1 exit status
_CFLAGS=${_CFLAGS/-fexceptions/}
_CXXFLAGS=${_CXXFLAGS/-fexceptions/}

# CFLAGS, CXXFLAGS and LDFLAGS are ignored as shown by a warning
# in the output of ./configure unless used like such:
#  --with-extra-cflags="${CFLAGS}"
#  --with-extra-cxxflags="${CXXFLAGS}"
#  --with-extra-ldflags="${LDFLAGS}"
# See also paragraph "Configure Control Variables from "jdk26-jdk-26.0.1+8/common/doc/building.md
unset CFLAGS
unset CXXFLAGS
unset LDFLAGS

jvm_features="zgc,shenandoahgc"

if (( HOKUTO_LTO == 1 )); then
    jvm_features+=",link-time-opt"
fi

bash configure \
  --with-version-string="$2" \
  --with-stdc++lib=dynamic \
  --with-extra-cflags="${_CFLAGS}" \
  --with-extra-cxxflags="${_CXXFLAGS}" \
  --with-extra-ldflags="${_LDFLAGS}" \
  --with-libjpeg=system \
  --with-giflib=system \
  --with-libpng=system \
  --with-lcms=system \
  --with-zlib=system \
  --with-harfbuzz=system \
  --with-jvm-features="${jvm_features}" \
  --with-native-debug-symbols=none \
  --with-debug-level=release \
  --enable-unlimited-crypto \
  --disable-warnings-as-errors \
  --with-vendor-name="sauzerOS"

make images legacy-jre-image

# https://bugs.openjdk.java.net/browse/JDK-8173610
find "build/linux-${HOKUTO_ARCH}-server-release/images" -iname '*.so' -exec chmod +x {} \;

major_version="${2%%.*}"
images_dir="build/linux-${HOKUTO_ARCH}-server-release/images"
jdk_image="$images_dir/jdk"
legacy_jre_image="$images_dir/jre"
java_home="/usr/lib/jvm/java-${major_version}-openjdk"
jre_pkgdir="$HOKUTO_SPLIT_DIR/java-openjdk-jre"

if [[ ! -d "$jdk_image" || ! -d "$legacy_jre_image" ]]; then
    echo "OpenJDK images were not created in $images_dir" >&2
    exit 1
fi

# The JRE owns the shared Java home: the complete module image is also needed by
# javac and the other development tools. Keeping it here lets the JDK package
# depend on the JRE without shipping a second copy of the runtime.
install -d "$jre_pkgdir$java_home" "$jre_pkgdir/usr/bin"
cp -a \
    "$jdk_image/conf" \
    "$jdk_image/legal" \
    "$jdk_image/lib" \
    "$jdk_image/release" \
    "$jre_pkgdir$java_home/"

# Sources are development reference material rather than a runtime requirement;
# discard them together with the demos, documentation, and man pages.
rm -f "$jre_pkgdir$java_home/lib/src.zip"

# Use the system-managed JKS trust store generated by ca-certificates. This
# keeps Java's trusted roots synchronized with the rest of sauzerOS.
rm -f "$jre_pkgdir$java_home/lib/security/cacerts"
ln -s /etc/pki/tls/java/cacerts \
    "$jre_pkgdir$java_home/lib/security/cacerts"

# Use the legacy JRE image only as the authoritative list of runtime launchers.
# Install the matching launchers from the full image so they use the shared
# full module image above.
install -d "$jre_pkgdir$java_home/bin"
for runtime_bin in "$legacy_jre_image"/bin/*; do
    tool="${runtime_bin##*/}"
    install -m755 "$jdk_image/bin/$tool" "$jre_pkgdir$java_home/bin/$tool"
    ln -s "../lib/jvm/java-${major_version}-openjdk/bin/$tool" \
        "$jre_pkgdir/usr/bin/$tool"
done

# Runtime desktop integration and icons belong to the JRE.
install -Dm644 freedesktop-java.desktop \
    "$jre_pkgdir/usr/share/applications/java-openjdk-${major_version}.desktop"
for size in 16 24 32 48; do
    install -Dm644 "src/java.desktop/unix/classes/sun/awt/X11/java-icon${size}.png" \
        "$jre_pkgdir/usr/share/icons/hicolor/${size}x${size}/apps/java${major_version}-openjdk.png"
done

# The main package contains only the development portion of the JDK. Its
# package-specific dependency metadata makes it pull in java-openjdk-jre.
install -d "$1$java_home/bin" "$1$java_home/include" "$1$java_home/jmods" "$1/usr/bin"
cp -a "$jdk_image/include/." "$1$java_home/include/"
cp -a "$jdk_image/jmods/." "$1$java_home/jmods/"

for development_bin in "$jdk_image"/bin/*; do
    tool="${development_bin##*/}"
    if [[ -e "$legacy_jre_image/bin/$tool" ]]; then
        continue
    fi
    install -m755 "$development_bin" "$1$java_home/bin/$tool"
    ln -s "../lib/jvm/java-${major_version}-openjdk/bin/$tool" \
        "$1/usr/bin/$tool"
done

install -Dm644 freedesktop-jconsole.desktop \
    "$1/usr/share/applications/jconsole-openjdk-${major_version}.desktop"
install -Dm644 freedesktop-jshell.desktop \
    "$1/usr/share/applications/jshell-openjdk-${major_version}.desktop"
